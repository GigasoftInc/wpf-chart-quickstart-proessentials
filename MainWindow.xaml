<Window x:Class="ProEssentialsWpfQuickstart.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProEssentialsWpfQuickstart"
        xmlns:Gigasoft="clr-namespace:Gigasoft.ProEssentials;assembly=Gigasoft.ProEssentialsWpf"
        mc:Ignorable="d"
        Title="ProEssentials WPF Quickstart" Height="640" Width="1280"
        MinWidth="400" MinHeight="400"
        Loaded="Window_Loaded" Closing="Window_Closing"
        Name="Main" UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="35" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Name="ChartContainer">
            <Border Name="PeContainer" BorderThickness="1" Visibility="Visible">
                <Gigasoft:PesgoWpf Name="Pesgo1" />
            </Border>
        </Grid>
        <Grid Grid.Row="1" Name="ExtraContainer">
            <Button Name="Button1" Content="Button1" MaxWidth="130" MinWidth="130"
                    HorizontalAlignment="Left" MinHeight="30" Margin="0,0,0,0" />
            <Button Name="Button2" Content="Button2" MaxWidth="130" MinWidth="130"
                    HorizontalAlignment="Left" MinHeight="30" Margin="160,0,0,0" />
            <Button Name="Button3" Content="Button3" MaxWidth="130" MinWidth="130"
                    HorizontalAlignment="Left" MinHeight="30" Margin="320,0,0,0" />
            <Label Name="Label1" Content="Label1"
                   HorizontalAlignment="Left" MinHeight="30" Margin="480,0,0,0" />
        </Grid>
    </Grid>
</Window>